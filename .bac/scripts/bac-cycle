#!/usr/bin/env bash
set -euo pipefail

VALID_AGENTS=(po dev qa)
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<EOF
Uso: bac-cycle [--repo <path|.|url>] [--agent <agente>] [ações...]

Opções:
  --repo          Caminho local, '.' para o diretório atual, ou URL do GitHub (padrão: .)
  --agent         Agente executor: po | dev | qa (inferido pela ação se omitido)
  -h, --help      Exibe esta ajuda

Ações e agente padrão:
  --install       po   — instala o .bac no repositório
  --status        dev  — exibe estado atual do backlog
  --refine <ID>   po   — ciclo de refinamento via IA

Exemplos:
  bac-cycle --repo . --refine FEAT-001
  bac-cycle --repo . --status
  bac-cycle --repo byselvs/workspace --install --status
  bac-cycle --repo . --agent qa --status
EOF
}

die() {
  echo "erro: $*" >&2
  echo "" >&2
  usage >&2
  exit 1
}

# --- parse args ---

REPO="."
REPO_ORIGINAL="."
AGENT=""
ACTIONS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ -n "${2:-}" ]] || die "--repo requer um valor"
      REPO="$2"; REPO_ORIGINAL="$2"; shift 2 ;;
    --agent)
      [[ -n "${2:-}" ]] || die "--agent requer um valor"
      AGENT="$2"; shift 2 ;;
    --install)       ACTIONS+=(install);          shift ;;
    --status)        ACTIONS+=(status);           shift ;;
    --refine)
      [[ -n "${2:-}" ]] || die "--refine requer um ID (ex: FEAT-001)"
      ACTIONS+=("refine:$2");                     shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *)         die "argumento desconhecido: $1" ;;
  esac
done

# --- validações ---

[[ -n "$REPO" ]]           || REPO="."
[[ ${#ACTIONS[@]} -gt 0 ]] || die "nenhuma ação especificada"

is_valid_agent() {
  local a="$1"
  for valid in "${VALID_AGENTS[@]}"; do
    [[ "$a" == "$valid" ]] && return 0
  done
  return 1
}

default_agent_for() {
  case "$1" in
    install) echo "po"  ;;
    refine)  echo "po"  ;;
    status)  echo "dev" ;;
    *)       echo ""    ;;
  esac
}

if [[ -z "$AGENT" ]]; then
  inferred=""
  for _a in "${ACTIONS[@]}"; do
    _def="$(default_agent_for "${_a%%:*}")"
    if [[ -z "$inferred" ]]; then
      inferred="$_def"
    elif [[ "$inferred" != "$_def" ]]; then
      die "--agent é obrigatório quando as ações têm agentes padrão diferentes (${ACTIONS[*]})"
    fi
  done
  AGENT="${inferred:-dev}"
fi

is_valid_agent "$AGENT" || die "agente inválido: '$AGENT'. Use: ${VALID_AGENTS[*]}"

# --- setup do repositório ---

CLONED_DIR=""
BAC_CLONE_DIR=""

cleanup() {
  if [[ -n "$CLONED_DIR" ]]; then
    rm -rf "$CLONED_DIR"
  fi
  if [[ -n "$BAC_CLONE_DIR" ]]; then
    rm -rf "$BAC_CLONE_DIR"
  fi
}
trap cleanup EXIT

to_https_url() {
  local input="$1"
  if [[ "$input" =~ ^git@github\.com:(.+)$ ]]; then
    echo "https://github.com/${BASH_REMATCH[1]}"
  else
    echo "$input"
  fi
}

to_ssh_url() {
  local input="$1"
  if [[ "$input" =~ ^git@github\.com: ]]; then
    echo "$input"
  elif [[ "$input" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*/[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
    echo "git@github.com:${input}.git"
  elif [[ "$input" =~ ^https://github\.com/(.+)$ ]]; then
    local path="${BASH_REMATCH[1]%.git}"
    echo "git@github.com:${path}.git"
  fi
}

is_local_path() {
  [[ "$1" == "."   ]] || \
  [[ "$1" == "./"* ]] || \
  [[ "$1" == "/"*  ]] || \
  [[ -d "$1"       ]]
}

if is_local_path "$REPO"; then
  [[ -d "$REPO" ]] || die "repositório não encontrado: $REPO"
  REPO="$(cd "$REPO" && pwd)"
else
  SSH_URL="$(to_ssh_url "$REPO")"
  [[ -n "$SSH_URL" ]] || die "valor inválido para --repo: $REPO"
  echo "clonando $SSH_URL..."
  CLONED_DIR="$(mktemp -d)"
  git clone --depth 1 "$SSH_URL" "$CLONED_DIR" || die "falha ao clonar: $SSH_URL"
  REPO="$CLONED_DIR"
fi

[[ -d "$REPO" ]]      || die "repositório não encontrado: $REPO"
[[ -d "$REPO/.git" ]] || die "não é um repositório git: $REPO"

# --- verificação do .bac ---

has_install_action() {
  local a
  for a in "${ACTIONS[@]}"; do
    [[ "$a" == "install" ]] && return 0
  done
  return 1
}

if [[ ! -d "$REPO/.bac" ]]; then
  if has_install_action; then
    : # deixa o action_install criar o .bac
  else
    echo "este repositório não tem .bac instalado." >&2
    echo "" >&2
    echo "execute novamente com --install:" >&2
    echo "" >&2
    echo "  bac-cycle --repo $REPO_ORIGINAL --agent $AGENT --install ${ACTIONS[*]/#/--}" >&2
    exit 1
  fi
fi

# --- helpers ---

refine_has_content() {
  awk '/^---$/{found=1; next} found && /\S/{has=1} END{exit !has}' "$1"
}

# --- permissões por agente ---

agent_can() {
  local action="$1"
  case "$AGENT" in
    po)  [[ "$action" == install || "$action" == status || "$action" == refine ]] ;;
    dev) [[ "$action" == install || "$action" == status ]] ;;
    qa)  [[ "$action" == install || "$action" == status ]] ;;
  esac
}

for action in "${ACTIONS[@]}"; do
  action_type="${action%%:*}"
  agent_can "$action_type" || die "agente '$AGENT' não tem permissão para: --$action_type"
done

# --- ações ---

action_install() {
  if [[ -d "$REPO/.bac" ]]; then
    echo ".bac já existe em $REPO — pulando instalação"
    return
  fi

  local bac_url bac_url_https
  bac_url="$(git -C "$SCRIPTS_DIR" remote get-url origin 2>/dev/null)" \
    || die "não foi possível determinar a URL do repositório bac"
  bac_url_https="$(to_https_url "$bac_url")"

  echo "clonando bac de $bac_url_https..."
  BAC_CLONE_DIR="$(mktemp -d)"
  git clone --depth 1 "$bac_url_https" "$BAC_CLONE_DIR" \
    || die "falha ao clonar o repositório bac"

  echo "instalando .bac em $REPO..."

  mkdir -p "$REPO/.bac/draft" "$REPO/.bac/backlog" "$REPO/.bac/sprint-001"

  for f in BAC.md CONFIG.yaml CONTEXT.md TEAM.md; do
    cp "$BAC_CLONE_DIR/.bac/$f" "$REPO/.bac/$f"
  done

  mkdir -p "$REPO/.bac/scripts"
  for script in bac-next-feat bac-next-sprint; do
    cp "$BAC_CLONE_DIR/.bac/scripts/$script" "$REPO/.bac/scripts/$script"
    chmod +x "$REPO/.bac/scripts/$script"
  done

  cat > "$REPO/.bac/sprint-001/SPRINT.md" <<'EOF'
---
status: OPEN
---

# Sprint 001
EOF

  echo ".bac instalado em $REPO"
}

mark_refined() {
  local file="$1"
  local ts; ts="$(date +%Y-%m-%dT%H:%M)"
  if grep -q '^refined_at:' "$file"; then
    sed -i "s|^refined_at:.*|refined_at: $ts|" "$file"
  else
    awk -v ts="$ts" '
      NR==1 && /^---$/ { in_front=1; print; next }
      in_front && /^---$/ { print "refined_at: " ts; in_front=0 }
      { print }
    ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
  fi
}

action_refine() {
  local id="$1"

  local item
  item=$(find "$REPO/.bac/draft" -maxdepth 1 -name "${id}-*.md" \
    ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | head -1)
  [[ -n "$item" ]] || die "item '$id' not found in draft/"

  local note_files=()
  while IFS= read -r f; do note_files+=("$f"); done < <(
    find "$REPO/.bac/draft" -maxdepth 1 \
      -name "${id}-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
      2>/dev/null | sort)

  local blocker_files=()
  while IFS= read -r f; do blocker_files+=("$f"); done < <(
    find "$REPO/.bac/draft" -maxdepth 1 \
      -name "${id}-blocker-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
      2>/dev/null | sort)

  local n_notes=${#note_files[@]}
  local n_blockers=${#blocker_files[@]}
  echo "refining $id — $n_notes note(s), $n_blockers open blocker(s)..."

  local item_rel
  item_rel="$(realpath --relative-to="$REPO" "$item")"

  local notes_list="" blockers_list=""
  for f in "${note_files[@]}"; do
    notes_list+="- $(realpath --relative-to="$REPO" "$f")"$'\n'
  done
  for f in "${blocker_files[@]}"; do
    blockers_list+="- $(realpath --relative-to="$REPO" "$f")"$'\n'
  done

  local notes_section blockers_section
  if [[ $n_notes -gt 0 ]]; then
    notes_section="USER NOTES TO INCORPORATE (read, incorporate into spec, then delete these files):
${notes_list}"
  else
    notes_section="USER NOTES: none."
  fi

  if [[ $n_blockers -gt 0 ]]; then
    blockers_section="OPEN BLOCKERS — questions from a previous refine cycle awaiting PO answers.
Check if any user note resolves them. Delete resolved blocker files. Leave unresolved ones untouched.
${blockers_list}"
  else
    blockers_section="OPEN BLOCKERS: none."
  fi

  local new_blocker_path=".bac/draft/${id}-blocker-$(date +%Y%m%d-%H%M).md"

  local prompt
  prompt="$(cat <<PROMPT
You are a Product Owner running a refinement cycle in the BAC (Backlog-as-Code) system.

== PROJECT CONTEXT ==
Read these files first to understand the project stack, team, and decisions already made:
- .bac/CONTEXT.md
- .bac/TEAM.md
- .bac/CONFIG.yaml (if it exists)

== ITEM TO REFINE ==
${item_rel}

== ${notes_section}

== ${blockers_section}

== YOUR TASKS (execute in order) ==

1. Read the project context files and the item spec.

2. If there are user notes: incorporate their content into the spec. Delete the note files after processing.

3. If there are open blockers: check if any user note answers or resolves them. Delete the resolved blocker files. Leave unresolved ones untouched.

4. Expand and complete the spec based on the project context. Think about what a developer needs to fully implement this item — fill in missing details, acceptance criteria, edge cases, technical constraints, and dependencies.

5. Assess if there are still open questions that ONLY the PO can decide (things that cannot be inferred from the project context). Examples: which OAuth provider, business rules, scope decisions, naming, integrations.

6. If there are unanswered questions:
   Create a blocker file at: ${new_blocker_path}
   Format:
   # Blocker — ${id}: <item title>
   > Generated by refine cycle. Answer each question via: bac --comment ${id} --text "..."

   1. **<Topic>**: <Clear, specific question>
   2. ...

7. If the spec is complete and no decisions are missing, do NOT create a blocker file.

Preserve the YAML frontmatter, status badge, and section structure. Do not add or modify refined_at in the frontmatter.
PROMPT
)"

  echo "calling claude..."

  (cd "$REPO" && echo "$prompt" | claude --print --verbose \
    --output-format stream-json \
    --include-partial-messages \
    --allowedTools "Read,Write,Edit,Bash,Glob,Grep,LS") \
  | python3 -c "
import sys, json

prev_len   = 0
seen_tools = set()
last_in    = 0
last_out   = 0

def tool_detail(name, inp):
    if 'file_path' in inp: return inp['file_path']
    if 'command'   in inp: c = inp['command']; return (c[:60] + '…') if len(c) > 60 else c
    if 'path'      in inp: return inp['path']
    return ''

for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        ev = json.loads(raw)
    except Exception:
        continue

    t = ev.get('type', '')

    if t == 'assistant':
        msg     = ev.get('message', {})
        usage   = msg.get('usage', {})
        in_tok  = usage.get('input_tokens',  0)
        out_tok = usage.get('output_tokens', 0)
        if in_tok  > last_in:  last_in  = in_tok
        if out_tok > last_out: last_out = out_tok
        in_tok  = last_in
        out_tok = last_out

        content = msg.get('content', [])
        for b in content:
            if b.get('type') == 'tool_use':
                tid = b.get('id', b.get('name', ''))
                if tid not in seen_tools:
                    seen_tools.add(tid)
                    detail = tool_detail(b['name'], b.get('input', {}))
                    sys.stdout.write(
                        f\"\n  ↳ {b['name']:<8} {detail:<50}  ↑{in_tok} ↓{out_tok}\n\"
                    )
                    sys.stdout.flush()

        all_text = ''.join(b.get('text', '') for b in content if b.get('type') == 'text')
        if len(all_text) > prev_len:
            sys.stdout.write(all_text[prev_len:])
            sys.stdout.flush()
            prev_len = len(all_text)

    elif t == 'result':
        cost = ev.get('cost_usd') or ev.get('total_cost_usd') or 0
        sys.stdout.write('\n' + '─' * 60 + '\n')
        sys.stdout.write(f'tokens: ↑{last_in} in  ↓{last_out} out')
        if cost:
            sys.stdout.write(f'  |  \${cost:.4f}')
        sys.stdout.write('\n')
        sys.stdout.flush()
" || die "claude call failed"

  mark_refined "$item"

  local n_remaining
  n_remaining=$(find "$REPO/.bac/draft" -maxdepth 1 \
    -name "${id}-blocker-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | wc -l | tr -d ' ')

  local commit_msg
  if [[ $n_remaining -gt 0 ]]; then
    commit_msg="refine($id): spec updated, ${n_remaining} blocker(s) open"
  else
    commit_msg="refine($id): spec complete, no open blockers"
  fi

  git -C "$REPO" add .bac/draft/
  git -C "$REPO" diff --cached --quiet \
    || git -C "$REPO" commit -m "$commit_msg"
}

item_title() {
  grep -m1 '^# ' "$1" 2>/dev/null | sed 's/^# //'
}

item_note_count() {
  local id="$1" dir="$2"
  find "$dir" -maxdepth 1 \
    -name "${id}-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | wc -l | tr -d ' '
}

item_blocker_count() {
  local id="$1" dir="$2"
  find "$dir" -maxdepth 1 \
    -name "${id}-blocker-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | wc -l | tr -d ' '
}

action_status() {
  local bac="$REPO/.bac"

  # --- Draft ---
  local draft_files=()
  while IFS= read -r f; do draft_files+=("$f"); done < <(
    find "$bac/draft" -maxdepth 1 -name "*.md" \
      ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
      2>/dev/null | sort)
  local n_draft=${#draft_files[@]}

  echo "draft ($n_draft):"
  if [[ $n_draft -eq 0 ]]; then
    echo "  —"
  else
    for f in "${draft_files[@]}"; do
      local fid ftitle ftags fn
      fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
      ftitle="$(item_title "$f")"
      ftags=""
      grep -q '^refined_at:' "$f" || ftags+=" [unrefined]"
      local fb fn
      fb="$(item_blocker_count "$fid" "$bac/draft")"
      fn="$(item_note_count    "$fid" "$bac/draft")"
      [[ "$fb" -gt 0 ]] && ftags+=" [${fb} blocker(s)]"
      [[ "$fn" -gt 0 ]] && ftags+=" [${fn} note(s)]"
      printf "  %-10s  %-45s%s\n" "$fid" "${ftitle:0:45}" "$ftags"
    done
  fi

  echo ""

  # --- Backlog ---
  local backlog_files=()
  while IFS= read -r f; do backlog_files+=("$f"); done < <(
    find "$bac/backlog" -maxdepth 1 -name "*.md" 2>/dev/null | sort)
  local n_backlog=${#backlog_files[@]}

  echo "backlog ($n_backlog):"
  if [[ $n_backlog -eq 0 ]]; then
    echo "  —"
  else
    for f in "${backlog_files[@]}"; do
      local fid ftitle
      fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
      ftitle="$(item_title "$f")"
      printf "  %-10s  %s\n" "$fid" "${ftitle:0:55}"
    done
  fi

  echo ""

  # --- Sprint ---
  local open_sprint=""
  open_sprint=$(grep -rl "status: OPEN" "$bac"/sprint-*/SPRINT.md 2>/dev/null | head -1 || true)

  if [[ -n "$open_sprint" ]]; then
    local sprint_dir sprint_label
    sprint_dir="$(dirname "$open_sprint")"
    sprint_label="$(basename "$sprint_dir")"

    local ready_files=() pending_files=()
    while IFS= read -r f; do
      [[ "$(basename "$f")" == "SPRINT.md" ]] && continue
      if grep -q 'BAC:.*:READY' "$f" 2>/dev/null; then
        ready_files+=("$f")
      else
        pending_files+=("$f")
      fi
    done < <(find "$sprint_dir" -maxdepth 1 -name "*.md" ! -name "SPRINT.md" 2>/dev/null | sort)

    local n_ready=${#ready_files[@]} n_pending=${#pending_files[@]}
    local n_sprint=$(( n_ready + n_pending ))

    echo "$sprint_label ($n_sprint items | $n_ready ready):"

    echo "  ready:"
    if [[ $n_ready -eq 0 ]]; then
      echo "    —"
    else
      for f in "${ready_files[@]}"; do
        local fid ftitle
        fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
        ftitle="$(item_title "$f")"
        printf "    %-10s  %s\n" "$fid" "${ftitle:0:50}"
      done
    fi

    echo "  pending:"
    if [[ $n_pending -eq 0 ]]; then
      echo "    —"
    else
      for f in "${pending_files[@]}"; do
        local fid ftitle
        fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
        ftitle="$(item_title "$f")"
        printf "    %-10s  %s\n" "$fid" "${ftitle:0:50}"
      done
    fi
  else
    echo "sprint: — (no open sprint)"
  fi

  echo ""
}

for action in "${ACTIONS[@]}"; do
  action_type="${action%%:*}"
  action_arg="${action#*:}"
  case "$action_type" in
    install) action_install ;;
    status)  action_status  ;;
    refine)  action_refine "$action_arg" ;;
  esac
done
