#!/usr/bin/env bash
set -euo pipefail

VALID_AGENTS=(po dev qa)
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<EOF
Uso: bac-cycle [--repo <path|.|url>] [--agent <agente>] [ações...]

Opções:
  --repo          Caminho local, '.' para o diretório atual, ou URL do GitHub (padrão: .)
  --agent         Agente executor: po | dev | qa (inferido pela ação se omitido)
  -h, --help      Exibe esta ajuda

Ações e agente padrão:
  --install       po   — instala o .bac no repositório
  --status        dev  — exibe estado atual do backlog
  --refine <ID>   po   — ciclo de refinamento via IA

Exemplos:
  bac-cycle --repo . --refine FEAT-001
  bac-cycle --repo . --status
  bac-cycle --repo byselvs/workspace --install --status
  bac-cycle --repo . --agent qa --status
EOF
}

die() {
  echo "erro: $*" >&2
  echo "" >&2
  usage >&2
  exit 1
}

# --- parse args ---

REPO="."
REPO_ORIGINAL="."
AGENT=""
ACTIONS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ -n "${2:-}" ]] || die "--repo requer um valor"
      REPO="$2"; REPO_ORIGINAL="$2"; shift 2 ;;
    --agent)
      [[ -n "${2:-}" ]] || die "--agent requer um valor"
      AGENT="$2"; shift 2 ;;
    --install)       ACTIONS+=(install);          shift ;;
    --status)        ACTIONS+=(status);           shift ;;
    --refine)
      [[ -n "${2:-}" ]] || die "--refine requer um ID (ex: FEAT-001)"
      ACTIONS+=("refine:$2");                     shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *)         die "argumento desconhecido: $1" ;;
  esac
done

# --- validações ---

[[ -n "$REPO" ]]           || REPO="."
[[ ${#ACTIONS[@]} -gt 0 ]] || die "nenhuma ação especificada"

is_valid_agent() {
  local a="$1"
  for valid in "${VALID_AGENTS[@]}"; do
    [[ "$a" == "$valid" ]] && return 0
  done
  return 1
}

default_agent_for() {
  case "$1" in
    install) echo "po"  ;;
    refine)  echo "po"  ;;
    status)  echo "dev" ;;
    *)       echo ""    ;;
  esac
}

if [[ -z "$AGENT" ]]; then
  inferred=""
  for _a in "${ACTIONS[@]}"; do
    _def="$(default_agent_for "${_a%%:*}")"
    if [[ -z "$inferred" ]]; then
      inferred="$_def"
    elif [[ "$inferred" != "$_def" ]]; then
      die "--agent é obrigatório quando as ações têm agentes padrão diferentes (${ACTIONS[*]})"
    fi
  done
  AGENT="${inferred:-dev}"
fi

is_valid_agent "$AGENT" || die "agente inválido: '$AGENT'. Use: ${VALID_AGENTS[*]}"

# --- setup do repositório ---

CLONED_DIR=""
BAC_CLONE_DIR=""

cleanup() {
  if [[ -n "$CLONED_DIR" ]]; then
    rm -rf "$CLONED_DIR"
  fi
  if [[ -n "$BAC_CLONE_DIR" ]]; then
    rm -rf "$BAC_CLONE_DIR"
  fi
}
trap cleanup EXIT

to_https_url() {
  local input="$1"
  if [[ "$input" =~ ^git@github\.com:(.+)$ ]]; then
    echo "https://github.com/${BASH_REMATCH[1]}"
  else
    echo "$input"
  fi
}

to_ssh_url() {
  local input="$1"
  if [[ "$input" =~ ^git@github\.com: ]]; then
    echo "$input"
  elif [[ "$input" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*/[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
    echo "git@github.com:${input}.git"
  elif [[ "$input" =~ ^https://github\.com/(.+)$ ]]; then
    local path="${BASH_REMATCH[1]%.git}"
    echo "git@github.com:${path}.git"
  fi
}

is_local_path() {
  [[ "$1" == "."   ]] || \
  [[ "$1" == "./"* ]] || \
  [[ "$1" == "/"*  ]] || \
  [[ -d "$1"       ]]
}

if is_local_path "$REPO"; then
  [[ -d "$REPO" ]] || die "repositório não encontrado: $REPO"
  REPO="$(cd "$REPO" && pwd)"
else
  SSH_URL="$(to_ssh_url "$REPO")"
  [[ -n "$SSH_URL" ]] || die "valor inválido para --repo: $REPO"
  echo "clonando $SSH_URL..."
  CLONED_DIR="$(mktemp -d)"
  git clone --depth 1 "$SSH_URL" "$CLONED_DIR" || die "falha ao clonar: $SSH_URL"
  REPO="$CLONED_DIR"
fi

[[ -d "$REPO" ]]      || die "repositório não encontrado: $REPO"
[[ -d "$REPO/.git" ]] || die "não é um repositório git: $REPO"

# --- verificação do .bac ---

has_install_action() {
  local a
  for a in "${ACTIONS[@]}"; do
    [[ "$a" == "install" ]] && return 0
  done
  return 1
}

if [[ ! -d "$REPO/.bac" ]]; then
  if has_install_action; then
    : # deixa o action_install criar o .bac
  else
    echo "este repositório não tem .bac instalado." >&2
    echo "" >&2
    echo "execute novamente com --install:" >&2
    echo "" >&2
    echo "  bac-cycle --repo $REPO_ORIGINAL --agent $AGENT --install ${ACTIONS[*]/#/--}" >&2
    exit 1
  fi
fi

# --- helpers ---

refine_has_content() {
  awk '/^---$/{found=1; next} found && /\S/{has=1} END{exit !has}' "$1"
}

# --- permissões por agente ---

agent_can() {
  local action="$1"
  case "$AGENT" in
    po)  [[ "$action" == install || "$action" == status || "$action" == refine ]] ;;
    dev) [[ "$action" == install || "$action" == status ]] ;;
    qa)  [[ "$action" == install || "$action" == status ]] ;;
  esac
}

for action in "${ACTIONS[@]}"; do
  action_type="${action%%:*}"
  agent_can "$action_type" || die "agente '$AGENT' não tem permissão para: --$action_type"
done

# --- ações ---

action_install() {
  if [[ -d "$REPO/.bac" ]]; then
    echo ".bac já existe em $REPO — pulando instalação"
    return
  fi

  local bac_url bac_url_https
  bac_url="$(git -C "$SCRIPTS_DIR" remote get-url origin 2>/dev/null)" \
    || die "não foi possível determinar a URL do repositório bac"
  bac_url_https="$(to_https_url "$bac_url")"

  echo "clonando bac de $bac_url_https..."
  BAC_CLONE_DIR="$(mktemp -d)"
  git clone --depth 1 "$bac_url_https" "$BAC_CLONE_DIR" \
    || die "falha ao clonar o repositório bac"

  echo "instalando .bac em $REPO..."

  mkdir -p "$REPO/.bac/draft" "$REPO/.bac/backlog" "$REPO/.bac/sprint-001"

  for f in BAC.md README.md CONFIG.yaml CONTEXT.md TEAM.md TEMPLATE-FEATURE.md TEMPLATE-BUG.md; do
    cp "$BAC_CLONE_DIR/.bac/$f" "$REPO/.bac/$f"
  done

  mkdir -p "$REPO/.bac/scripts"
  for script in bac-next-feat bac-next-sprint; do
    cp "$BAC_CLONE_DIR/.bac/scripts/$script" "$REPO/.bac/scripts/$script"
    chmod +x "$REPO/.bac/scripts/$script"
  done

  cat > "$REPO/.bac/sprint-001/SPRINT.md" <<'EOF'
---
status: OPEN
---

# Sprint 001 — Getting Started

**Objetivo:** Configurar o projeto, definir contexto e criar as primeiras tarefas no BAC.

## Retrospectiva

_(preencher ao fechar a sprint — 3 frases: bom, ruim, ajustar.)_
EOF

  cat > "$REPO/.bac/draft/FEAT-001-getting-started.md" <<'EOF'
---
priority: P1
---

<!-- BAC:FEATURE:DRAFT id=FEAT-001 -->

> 📝 **`DRAFT`** — spec em construção, ainda não pode ser implementado

# Getting Started

## Contexto

Este é o primeiro item do BAC neste repositório. Use-o como referência de
formato ou substitua pelo seu primeiro item real.

## Proposta

Configurar o projeto: definir stack, ambientes, branches e primeiros passos
de desenvolvimento.

## Escopo

### Dentro do escopo
- Preencher `.bac/CONTEXT.md` com stack e arquitetura do projeto
- Preencher `.bac/TEAM.md` com pessoas e agentes envolvidos
- Criar `AGENTS.md` e `CLAUDE.md` na raiz do repositório

### Fora do escopo
- Qualquer implementação de funcionalidade real

## Critérios de aceite

- [ ] `CONTEXT.md` descreve a stack e os ambientes do projeto
- [ ] `TEAM.md` lista as pessoas e seus papéis
- [ ] `AGENTS.md` existe na raiz com instruções para agentes de IA

## Como testar

Abrir uma sessão do Claude Code e pedir "leia o AGENTS.md" — o agente deve
entender o projeto sem explicação adicional.

## Notas / decisões

Substitua este item pelo seu primeiro item real quando estiver pronto.
EOF

  echo ".bac instalado em $REPO"
}

action_refine() {
  local id="$1"

  local item
  item=$(find "$REPO/.bac/draft" -maxdepth 1 -name "${id}-*.md" \
    ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | head -1)
  [[ -n "$item" ]] || die "item '$id' não encontrado em draft/"

  local refine_files=()
  while IFS= read -r f; do
    refine_files+=("$f")
  done < <(find "$REPO/.bac/draft" -maxdepth 1 \
    -name "${id}-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | sort)

  [[ ${#refine_files[@]} -gt 0 ]] || die "nenhum arquivo de refinamento encontrado para $id"

  local n=${#refine_files[@]}
  echo "refinando $id ($n nota(s) do usuário)..."

  local item_rel refine_list=""
  item_rel="$(realpath --relative-to="$REPO" "$item")"
  for f in "${refine_files[@]}"; do
    refine_list+="- $(realpath --relative-to="$REPO" "$f")"$'\n'
  done

  local prompt
  prompt="$(cat <<PROMPT
Você é um Product Owner refinando uma história de usuário no sistema BAC (Backlog-as-Code).

Tarefa:
1. Leia a história: ${item_rel}
2. Leia os comentários do usuário:
${refine_list}
3. Atualize a história incorporando os comentários (mantenha frontmatter YAML, badge de status e estrutura de seções)
4. Apague os arquivos de comentários após processar

Se os comentários forem vazios ou não tiverem conteúdo útil, mantenha a história como está e apague os arquivos assim mesmo.
PROMPT
)"

  echo "chamando claude..."

  (cd "$REPO" && echo "$prompt" | claude --print --verbose \
    --output-format stream-json \
    --include-partial-messages \
    --allowedTools "Read,Write,Edit,Bash,Glob,Grep,LS") \
  | python3 -c "
import sys, json

prev_len   = 0
seen_tools = set()
last_in    = 0
last_out   = 0

def tool_detail(name, inp):
    if 'file_path' in inp: return inp['file_path']
    if 'command'   in inp: c = inp['command']; return (c[:60] + '…') if len(c) > 60 else c
    if 'path'      in inp: return inp['path']
    return ''

for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        ev = json.loads(raw)
    except Exception:
        continue

    t = ev.get('type', '')

    if t == 'assistant':
        msg     = ev.get('message', {})
        usage   = msg.get('usage', {})
        in_tok  = usage.get('input_tokens',  0)
        out_tok = usage.get('output_tokens', 0)
        if in_tok  > last_in:  last_in  = in_tok
        if out_tok > last_out: last_out = out_tok
        in_tok  = last_in
        out_tok = last_out

        content = msg.get('content', [])
        for b in content:
            if b.get('type') == 'tool_use':
                tid = b.get('id', b.get('name', ''))
                if tid not in seen_tools:
                    seen_tools.add(tid)
                    detail = tool_detail(b['name'], b.get('input', {}))
                    sys.stdout.write(
                        f\"\n  ↳ {b['name']:<8} {detail:<50}  ↑{in_tok} ↓{out_tok}\n\"
                    )
                    sys.stdout.flush()

        all_text = ''.join(b.get('text', '') for b in content if b.get('type') == 'text')
        if len(all_text) > prev_len:
            sys.stdout.write(all_text[prev_len:])
            sys.stdout.flush()
            prev_len = len(all_text)

    elif t == 'result':
        cost = ev.get('cost_usd') or ev.get('total_cost_usd') or 0
        sys.stdout.write('\n' + '─' * 60 + '\n')
        sys.stdout.write(f'tokens: ↑{last_in} in  ↓{last_out} out')
        if cost:
            sys.stdout.write(f'  |  \${cost:.4f}')
        sys.stdout.write('\n')
        sys.stdout.flush()
" || die "falha ao chamar o claude"

  git -C "$REPO" add .bac/draft/
  git -C "$REPO" diff --cached --quiet \
    || git -C "$REPO" commit -m "refine($id): incorpora comentários via IA"
}

action_status() {
  local bac="$REPO/.bac"

  local n_draft n_backlog
  n_draft=$(find "$bac/draft" -maxdepth 1 -name "*.md" \
    ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | wc -l | tr -d ' ')
  n_backlog=$(find "$bac/backlog" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ')

  local open_sprint=""
  open_sprint=$(grep -rl "status: OPEN" "$bac"/sprint-*/SPRINT.md 2>/dev/null | head -1 || true)

  local sprint_label="—" n_sprint=0 n_ready=0
  if [[ -n "$open_sprint" ]]; then
    local sprint_dir
    sprint_dir="$(dirname "$open_sprint")"
    sprint_label="$(basename "$sprint_dir")"
    n_sprint=$(find "$sprint_dir" -maxdepth 1 -name "*.md" ! -name "SPRINT.md" 2>/dev/null | wc -l | tr -d ' ')
    n_ready=$(grep -rl "BAC:.*:READY" "$sprint_dir" 2>/dev/null | grep -v "SPRINT.md" | wc -l | tr -d ' ' || true)
  fi

  local comment_ids=() seen=""
  while IFS= read -r f; do
    refine_has_content "$f" || continue
    local id
    id="$(basename "$f" | grep -oP '^FEAT-[0-9]+')"
    [[ -n "$id" && "$seen" != *"|$id|"* ]] || continue
    seen="$seen|$id|"
    comment_ids+=("$id")
  done < <(find "$bac/draft" -maxdepth 1 \
    -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | sort)
  local n_comments=${#comment_ids[@]}

  echo "draft:           $n_draft item(s)"
  echo "backlog:         $n_backlog item(s)"
  echo "$sprint_label:  $n_sprint item(s) | $n_ready ready"
  if [[ $n_comments -gt 0 ]]; then
    echo "comentários:     $n_comments pendente(s) — ${comment_ids[*]}"
  fi
  echo "---"
  echo "próxima feature: $("$SCRIPTS_DIR/bac-next-feat" --repo "$REPO")"
  echo "próxima sprint:  $("$SCRIPTS_DIR/bac-next-sprint" --repo "$REPO")"
}

for action in "${ACTIONS[@]}"; do
  action_type="${action%%:*}"
  action_arg="${action#*:}"
  case "$action_type" in
    install) action_install ;;
    status)  action_status  ;;
    refine)  action_refine "$action_arg" ;;
  esac
done
