#!/usr/bin/env bash
# CLI manual do BAC — comandos executados pelo usuário dentro do repositório.
# Uso: bac [opções] --<comando> [argumento]
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<EOF
Uso: bac [--agent <agente>] [--repo <path>] --<comando> [argumento]

Opções:
  --repo <path>      Repositório alvo (padrão: diretório atual)
  --agent <agente>   Agente executor: po | dev | qa (inferido pela ação se omitido)
  -h, --help         Exibe esta ajuda

Comandos e agente padrão:
  --install                po   — instala o .bac no repositório
  --create feature|bug|task  po   — cria um novo item em draft/
  --comment <ID>           po   — adiciona um comentário/nota a um item
  --status                 dev  — exibe estado atual do backlog

Opções extras:
  --text "..."   texto inicial para --create (título) ou --comment (nota)
  --immediate    após --create ou --comment, executa imediatamente o refine via bac-cycle

Exemplos:
  bac --create feature --text "Login com Google"
  bac --create feature --text "Login com Google" --immediate
  bac --create bug --text "Botão não responde no mobile"
  bac --create task
  bac --comment FEAT-001 --text "considere dark mode"
  bac --comment FEAT-001 --text "usar Google OAuth" --immediate
  bac --status
EOF
}

die() { echo "erro: $*" >&2; echo "" >&2; usage >&2; exit 1; }

[[ $# -gt 0 ]] || { usage; exit 0; }

# --- parse ---

REPO="."
AGENT=""
COMMENT_TEXT=""
IMMEDIATE=false
LAST_ID=""
ACTIONS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)      [[ -n "${2:-}" ]] || die "--repo requer um valor";  REPO="$2";  shift 2 ;;
    --agent)     [[ -n "${2:-}" ]] || die "--agent requer um valor"; AGENT="$2"; shift 2 ;;
    --text)      [[ -n "${2:-}" ]] || die "--text requer um valor";  COMMENT_TEXT="$2"; shift 2 ;;
    --immediate) IMMEDIATE=true;                                                  shift ;;
    --install)   ACTIONS+=(install);                                              shift ;;
    --status)    if [[ -n "${2:-}" && "${2}" != --* ]]; then
                   ACTIONS+=("status:$2"); shift 2
                 else
                   ACTIONS+=(status);     shift
                 fi ;;
    --create)    [[ -n "${2:-}" ]] || die "--create requer um tipo (feature | bug | task)"
                 ACTIONS+=("create:$2");                                          shift 2 ;;
    --comment)   [[ -n "${2:-}" ]] || die "--comment requer um ID (ex: FEAT-001)"
                 ACTIONS+=("comment:$2");                                         shift 2 ;;
    -h|--help)   usage; exit 0 ;;
    *)           die "opção desconhecida: $1" ;;
  esac
done

[[ ${#ACTIONS[@]} -gt 0 ]] || die "nenhum comando especificado"

VALID_AGENTS=(po dev qa)
is_valid_agent() {
  local a="$1"
  for v in "${VALID_AGENTS[@]}"; do [[ "$a" == "$v" ]] && return 0; done
  return 1
}

default_agent_for() {
  case "$1" in
    install) echo "po"  ;;
    create)  echo "po"  ;;
    comment) echo "po"  ;;
    status)  echo "dev" ;;
    *)       echo ""    ;;
  esac
}

if [[ -z "$AGENT" ]]; then
  inferred=""
  for _a in "${ACTIONS[@]}"; do
    _def="$(default_agent_for "${_a%%:*}")"
    if [[ -z "$inferred" ]]; then
      inferred="$_def"
    elif [[ "$inferred" != "$_def" ]]; then
      die "--agent é obrigatório quando as ações têm agentes padrão diferentes (${ACTIONS[*]})"
    fi
  done
  AGENT="${inferred:-dev}"
fi

is_valid_agent "$AGENT" || die "agente inválido: '$AGENT'. Use: ${VALID_AGENTS[*]}"

# --- resolução do repositório ---

CLONED_DIR=""
cleanup() { if [[ -n "$CLONED_DIR" ]]; then rm -rf "$CLONED_DIR"; fi; }
trap cleanup EXIT

to_ssh_url() {
  local input="$1"
  if [[ "$input" =~ ^git@github\.com: ]]; then
    echo "$input"
  elif [[ "$input" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*/[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
    echo "git@github.com:${input}.git"
  elif [[ "$input" =~ ^https://github\.com/(.+)$ ]]; then
    local path="${BASH_REMATCH[1]%.git}"
    echo "git@github.com:${path}.git"
  fi
}

is_local_path() {
  [[ "$1" == "."   ]] || [[ "$1" == "./"* ]] || [[ "$1" == "/"* ]] || [[ -d "$1" ]]
}

if is_local_path "$REPO"; then
  [[ -d "$REPO" ]] || die "repositório não encontrado: $REPO"
  REPO="$(cd "$REPO" && pwd)"
else
  SSH_URL="$(to_ssh_url "$REPO")"
  [[ -n "$SSH_URL" ]] || die "valor inválido para --repo: $REPO"
  echo "clonando $SSH_URL..."
  CLONED_DIR="$(mktemp -d)"
  git clone --depth 1 "$SSH_URL" "$CLONED_DIR" || die "falha ao clonar: $SSH_URL"
  REPO="$CLONED_DIR"
fi

[[ -d "$REPO/.git" ]] || die "não é um repositório git: $REPO"

# --- helpers ---

# retorna 0 se o arquivo de refine tem conteúdo escrito pelo usuário após o ---
refine_has_content() {
  awk '/^---$/{found=1; next} found && /\S/{has=1} END{exit !has}' "$1"
}

# --- subcomandos ---

cmd_install() {
  [[ "$AGENT" == "po" || "$AGENT" == "dev" ]] \
    || die "agente '$AGENT' não tem permissão para: --install"
  [[ -d "$REPO/.bac" ]] && { echo ".bac já existe em $REPO"; return; }

  local bac_url bac_url_https
  bac_url="$(git -C "$SCRIPTS_DIR" remote get-url origin 2>/dev/null)" \
    || die "não foi possível determinar a URL do repositório bac"
  bac_url_https="${bac_url/git@github.com:/https://github.com/}"
  bac_url_https="${bac_url_https%.git}.git"

  echo "clonando bac de $bac_url_https..."
  local bac_clone
  bac_clone="$(mktemp -d)"
  git clone --depth 1 "$bac_url_https" "$bac_clone" || die "falha ao clonar o repositório bac"

  echo "instalando .bac em $REPO..."
  mkdir -p "$REPO/.bac/draft" "$REPO/.bac/backlog" "$REPO/.bac/sprint-001"

  for f in BAC.md CONFIG.yaml CONTEXT.md TEAM.md; do
    cp "$bac_clone/.bac/$f" "$REPO/.bac/$f"
  done

  mkdir -p "$REPO/.bac/scripts"
  for script in bac-next-feat bac-next-sprint bac; do
    cp "$bac_clone/.bac/scripts/$script" "$REPO/.bac/scripts/$script"
    chmod +x "$REPO/.bac/scripts/$script"
  done

  cat > "$REPO/.bac/sprint-001/SPRINT.md" <<'EOF'
---
status: OPEN
---

# Sprint 001
EOF

  rm -rf "$bac_clone"
  echo ".bac instalado em $REPO"
}

cmd_comment() {
  local id="$1"
  LAST_ID="$id"
  [[ "$AGENT" == "po" ]] || die "agente '$AGENT' não tem permissão para: --comment"
  [[ -d "$REPO/.bac" ]] || die "repositório sem .bac — rode 'bac install' primeiro"

  local item
  item=$(find "$REPO/.bac/draft" -maxdepth 1 -name "${id}-*.md" \
    ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | head -1)
  [[ -n "$item" ]] || die "'$id' não encontrado em draft/"

  local ts out
  ts="$(date +%Y%m%d-%H%M)"
  out="$REPO/.bac/draft/${id}-${ts}.md"

  local title slug
  title=$(grep "^# " "$item" | head -1 | sed 's/^# //')
  slug=$(basename "$item" .md)

  cat > "$out" <<EOF
# Comentário — ${id}: ${title}

> Este arquivo será lido pela IA no próximo ciclo associado a este item.
> Escreva abaixo suas notas, considerações ou ajustes.

Item: [${slug}.md](./${slug}.md)

---

${COMMENT_TEXT}
EOF

  echo "criado: $out"
}

item_title() {
  grep -m1 '^# ' "$1" 2>/dev/null | sed 's/^# //'
}

item_note_count() {
  local id="$1" dir="$2"
  find "$dir" -maxdepth 1 \
    -name "${id}-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | wc -l | tr -d ' '
}

item_blocker_count() {
  local id="$1" dir="$2"
  find "$dir" -maxdepth 1 \
    -name "${id}-blocker-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | wc -l | tr -d ' '
}

cmd_status() {
  [[ -d "$REPO/.bac" ]] || die "repositório sem .bac — rode 'bac install' primeiro"

  # --- Draft ---
  local draft_files=()
  while IFS= read -r f; do draft_files+=("$f"); done < <(
    find "$REPO/.bac/draft" -maxdepth 1 -name "*.md" \
      ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
      2>/dev/null | sort)
  local n_draft=${#draft_files[@]}

  echo "draft ($n_draft):"
  if [[ $n_draft -eq 0 ]]; then
    echo "  —"
  else
    for f in "${draft_files[@]}"; do
      local fid ftitle ftags fn
      fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
      ftitle="$(item_title "$f")"
      ftags=""
      grep -q '^refined_at:' "$f" || ftags+=" [unrefined]"
      local fb fn
      fb="$(item_blocker_count "$fid" "$REPO/.bac/draft")"
      fn="$(item_note_count    "$fid" "$REPO/.bac/draft")"
      [[ "$fb" -gt 0 ]] && ftags+=" [${fb} blocker(s)]"
      [[ "$fn" -gt 0 ]] && ftags+=" [${fn} note(s)]"
      printf "  %-10s  %-45s%s\n" "$fid" "${ftitle:0:45}" "$ftags"
    done
  fi

  echo ""

  # --- Backlog ---
  local backlog_files=()
  while IFS= read -r f; do backlog_files+=("$f"); done < <(
    find "$REPO/.bac/backlog" -maxdepth 1 -name "*.md" 2>/dev/null | sort)
  local n_backlog=${#backlog_files[@]}

  echo "backlog ($n_backlog):"
  if [[ $n_backlog -eq 0 ]]; then
    echo "  —"
  else
    for f in "${backlog_files[@]}"; do
      local fid ftitle
      fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
      ftitle="$(item_title "$f")"
      printf "  %-10s  %s\n" "$fid" "${ftitle:0:55}"
    done
  fi

  echo ""

  # --- Sprint ---
  local open_sprint=""
  open_sprint=$(grep -rl "status: OPEN" "$REPO/.bac"/sprint-*/SPRINT.md 2>/dev/null | head -1 || true)

  if [[ -n "$open_sprint" ]]; then
    local sprint_dir sprint_label
    sprint_dir="$(dirname "$open_sprint")"
    sprint_label="$(basename "$sprint_dir")"

    local ready_files=() pending_files=()
    while IFS= read -r f; do
      [[ "$(basename "$f")" == "SPRINT.md" ]] && continue
      if grep -q 'BAC:.*:READY' "$f" 2>/dev/null; then
        ready_files+=("$f")
      else
        pending_files+=("$f")
      fi
    done < <(find "$sprint_dir" -maxdepth 1 -name "*.md" ! -name "SPRINT.md" 2>/dev/null | sort)

    local n_ready=${#ready_files[@]} n_pending=${#pending_files[@]}
    local n_sprint=$(( n_ready + n_pending ))

    echo "$sprint_label ($n_sprint items | $n_ready ready):"

    echo "  ready:"
    if [[ $n_ready -eq 0 ]]; then
      echo "    —"
    else
      for f in "${ready_files[@]}"; do
        local fid ftitle
        fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
        ftitle="$(item_title "$f")"
        printf "    %-10s  %s\n" "$fid" "${ftitle:0:50}"
      done
    fi

    echo "  pending:"
    if [[ $n_pending -eq 0 ]]; then
      echo "    —"
    else
      for f in "${pending_files[@]}"; do
        local fid ftitle
        fid="$(basename "$f" | grep -oP '^[A-Z]+-[0-9]+')"
        ftitle="$(item_title "$f")"
        printf "    %-10s  %s\n" "$fid" "${ftitle:0:50}"
      done
    fi
  else
    echo "sprint: — (no open sprint)"
  fi

  echo ""
  echo "---"
  echo "next feature: $("$SCRIPTS_DIR/bac-next-feat" --repo "$REPO")"
  echo "next sprint:  $("$SCRIPTS_DIR/bac-next-sprint" --repo "$REPO")"
}

cmd_create() {
  local item_type="$1"
  [[ "$AGENT" == "po" ]] || die "agente '$AGENT' não tem permissão para: --create"
  [[ -d "$REPO/.bac" ]] || die "repositório sem .bac — rode 'bac --install' primeiro"

  local prefix badge
  case "$item_type" in
    feature) prefix="FEAT"; badge="FEATURE" ;;
    bug)     prefix="BUG";  badge="BUG"     ;;
    task)    prefix="TASK"; badge="TASK"     ;;
    *) die "tipo inválido: '$item_type'. Use: feature | bug | task" ;;
  esac

  local last next
  last=$(find "$REPO/.bac" -name "${prefix}-[0-9]*.md" 2>/dev/null \
    | grep -oP "${prefix}-\K[0-9]+" | sort -n | tail -1 || true)
  next=$(( 10#${last:-0} + 1 ))
  local id
  id="$(printf '%s-%03d' "$prefix" "$next")"

  local title slug
  if [[ -n "$COMMENT_TEXT" ]]; then
    title="$COMMENT_TEXT"
    slug="$(printf '%s' "$COMMENT_TEXT" \
      | iconv -f utf-8 -t ascii//TRANSLIT 2>/dev/null \
      | tr '[:upper:]' '[:lower:]' \
      | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-//; s/-$//' \
      | cut -c1-50)"
  else
    title="$id"
    slug="new-${item_type}"
  fi

  local out="$REPO/.bac/draft/${id}-${slug}.md"

  cat > "$out" <<EOF
---
priority: P2
type: ${item_type}
---

<!-- BAC:${badge}:DRAFT id=${id} -->

# ${title}

_(describe what and why — run \`bac-cycle --refine ${id}\` to expand this spec)_
EOF

  LAST_ID="$id"
  echo "criado: $out"
}

cmd_status_item() {
  local id="$1"
  [[ -d "$REPO/.bac" ]] || die "repositório sem .bac — rode 'bac --install' primeiro"

  # find item across all locations
  local item location=""
  item=$(find "$REPO/.bac/draft" -maxdepth 1 -name "${id}-*.md" \
    ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    2>/dev/null | head -1)
  [[ -n "$item" ]] && location="draft"

  if [[ -z "$location" ]]; then
    item=$(find "$REPO/.bac/backlog" -maxdepth 1 -name "${id}-*.md" 2>/dev/null | head -1)
    [[ -n "$item" ]] && location="backlog"
  fi

  if [[ -z "$location" ]]; then
    item=$(find "$REPO/.bac"/sprint-* -maxdepth 1 -name "${id}-*.md" \
      ! -name "SPRINT.md" 2>/dev/null | head -1)
    [[ -n "$item" ]] && location="$(basename "$(dirname "$item")")"
  fi

  [[ -n "$item" ]] || die "item '$id' not found"

  local title
  title="$(item_title "$item")"
  echo "${id}  ${title}"
  echo "  location:  ${location}"

  # refined_at
  local refined_at
  refined_at="$(grep '^refined_at:' "$item" 2>/dev/null | sed 's/refined_at: //' || true)"
  if [[ -n "$refined_at" ]]; then
    echo "  refined:   yes (${refined_at})"
  else
    echo "  refined:   no"
  fi

  # blockers — only exist in draft
  if [[ "$location" == "draft" ]]; then
    local blocker_files=()
    while IFS= read -r f; do blocker_files+=("$f"); done < <(
      find "$REPO/.bac/draft" -maxdepth 1 \
        -name "${id}-blocker-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
        2>/dev/null | sort)
    local n_blockers=${#blocker_files[@]}
    if [[ $n_blockers -gt 0 ]]; then
      echo "  blockers:  ${n_blockers} open"
      for f in "${blocker_files[@]}"; do echo "    → $(basename "$f")"; done
    else
      echo "  blockers:  none"
    fi

    local note_files=()
    while IFS= read -r f; do note_files+=("$f"); done < <(
      find "$REPO/.bac/draft" -maxdepth 1 \
        -name "${id}-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
        2>/dev/null | sort)
    local n_notes=${#note_files[@]}
    if [[ $n_notes -gt 0 ]]; then
      echo "  notes:     ${n_notes} pending"
      for f in "${note_files[@]}"; do echo "    → $(basename "$f")"; done
    else
      echo "  notes:     none"
    fi
  fi

  # sprint-specific: ready or pending
  if [[ "$location" == sprint-* ]]; then
    if grep -q 'BAC:.*:READY' "$item" 2>/dev/null; then
      echo "  status:    ready"
    else
      echo "  status:    pending"
    fi
  fi
}

for action in "${ACTIONS[@]}"; do
  action_type="${action%%:*}"
  action_arg="${action#*:}"
  LAST_ID=""
  case "$action_type" in
    install) cmd_install ;;
    create)  cmd_create "$action_arg" ;;
    comment) cmd_comment "$action_arg" ;;
    status)  [[ "$action" == *:* ]] && cmd_status_item "$action_arg" || cmd_status ;;
  esac
  if [[ "$IMMEDIATE" == true && -n "$LAST_ID" ]]; then
    echo ""
    bac-cycle --repo "$REPO" --refine "$LAST_ID"
  fi
done
