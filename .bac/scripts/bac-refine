#!/usr/bin/env bash
# Cria um arquivo de sugestão de refinamento para um item em draft/.
# Uso: bac-refine --repo <path|.|url> --agent <agente> <ID>
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<EOF
Uso: bac-refine --repo <path|.|url> --agent <agente> <ID>

Opções:
  --repo     Caminho local, '.' para o diretório atual, ou URL do GitHub
  --agent    Agente executor: po | dev | qa
  -h, --help Exibe esta ajuda

Exemplos:
  bac-refine --repo . --agent po FEAT-001
  bac-refine --repo byselvs/meu-projeto --agent po FEAT-002
EOF
}

die() { echo "erro: $*" >&2; echo "" >&2; usage >&2; exit 1; }

# --- parse args ---

REPO=""
AGENT=""
ID=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)    [[ -n "${2:-}" ]] || die "--repo requer um valor";  REPO="$2";  shift 2 ;;
    --agent)   [[ -n "${2:-}" ]] || die "--agent requer um valor"; AGENT="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    -*)        die "argumento desconhecido: $1" ;;
    *)         [[ -z "$ID" ]] || die "ID duplicado: $1"; ID="$1"; shift ;;
  esac
done

[[ -n "$REPO" ]]  || die "--repo é obrigatório"
[[ -n "$AGENT" ]] || die "--agent é obrigatório"
[[ -n "$ID" ]]    || die "ID obrigatório. Ex: FEAT-001"
[[ "$AGENT" == "po" ]] || die "apenas o agente 'po' pode refinar itens"

# --- setup do repositório ---

CLONED_DIR=""
cleanup() { if [[ -n "$CLONED_DIR" ]]; then rm -rf "$CLONED_DIR"; fi; }
trap cleanup EXIT

to_ssh_url() {
  local input="$1"
  if [[ "$input" =~ ^git@github\.com: ]]; then
    echo "$input"
  elif [[ "$input" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*/[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
    echo "git@github.com:${input}.git"
  elif [[ "$input" =~ ^https://github\.com/(.+)$ ]]; then
    local path="${BASH_REMATCH[1]%.git}"
    echo "git@github.com:${path}.git"
  fi
}

is_local_path() {
  [[ "$1" == "."   ]] || \
  [[ "$1" == "./"* ]] || \
  [[ "$1" == "/"*  ]] || \
  [[ -d "$1"       ]]
}

if is_local_path "$REPO"; then
  [[ -d "$REPO" ]] || die "repositório não encontrado: $REPO"
  REPO="$(cd "$REPO" && pwd)"
else
  SSH_URL="$(to_ssh_url "$REPO")"
  [[ -n "$SSH_URL" ]] || die "valor inválido para --repo: $REPO"
  echo "clonando $SSH_URL..."
  CLONED_DIR="$(mktemp -d)"
  git clone --depth 1 "$SSH_URL" "$CLONED_DIR" || die "falha ao clonar: $SSH_URL"
  REPO="$CLONED_DIR"
fi

[[ -d "$REPO/.git" ]] || die "não é um repositório git: $REPO"
[[ -d "$REPO/.bac" ]] || die "repositório sem .bac — rode --install primeiro"

# --- execução ---

item=$(find "$REPO/.bac/draft" -maxdepth 1 -name "${ID}-*.md" 2>/dev/null | head -1)
[[ -n "$item" ]] || die "'$ID' não encontrado em draft/"

out_dir="$REPO/.bac/refine"
out="$out_dir/${ID}.md"

if [[ -f "$out" ]]; then
  echo "já existe: $out"
  exit 0
fi

mkdir -p "$out_dir"

title=$(grep "^# " "$item" | head -1 | sed 's/^# //')
slug=$(basename "$item" .md)

cat > "$out" <<EOF
# Refinamento — ${ID}: ${title}

Item: [${slug}.md](../draft/${slug}.md)

---

## Checklist de qualidade do spec

- [ ] O **contexto** está claro? (por que este item existe, qual problema resolve?)
- [ ] A **proposta** descreve O QUÊ fazer, não como?
- [ ] O **escopo** lista explicitamente o que está FORA?
- [ ] Os **critérios de aceite** são verificáveis e específicos?
- [ ] O **como testar** tem passos concretos e reproduzíveis?

## Perguntas em aberto

- Quem é o usuário afetado por esta feature?
- Existem dependências com outros itens?
- Há riscos ou pontos de atenção técnica?
- A prioridade está alinhada com a sprint atual?

## Sugestões de melhoria

_(preencher após análise — pode ficar vazio se o spec já estiver completo)_

## Decisão

- [ ] Spec aprovado — pode ser promovido para READY
- [ ] Spec precisa de ajustes (descrever acima antes de promover)
EOF

echo "criado: $out"
