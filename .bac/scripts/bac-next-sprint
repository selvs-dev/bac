#!/usr/bin/env bash
# Imprime o número da próxima sprint disponível. Ex: sprint-003
# Uso: bac-next-sprint [--repo <path|.>]
set -euo pipefail

REPO="."

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    *) echo "uso: bac-next-sprint [--repo <path>]" >&2; exit 1 ;;
  esac
done

[[ "$REPO" == "." ]] && REPO="$(pwd)"
[[ -d "$REPO/.bac" ]] || { echo "erro: .bac não encontrado em $REPO" >&2; exit 1; }

last=$(find "$REPO/.bac" -maxdepth 1 -type d -name 'sprint-[0-9]*' 2>/dev/null \
  | grep -oP '[0-9]+$' \
  | sort -n \
  | tail -1)

next=$(( 10#${last:-0} + 1 ))
printf 'sprint-%03d\n' "$next"
