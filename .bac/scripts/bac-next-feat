#!/usr/bin/env bash
# Imprime o próximo ID de FEAT disponível. Ex: FEAT-003
# Uso: bac-next-feat [--repo <path|.>]
set -euo pipefail

REPO="."

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    *) echo "uso: bac-next-feat [--repo <path>]" >&2; exit 1 ;;
  esac
done

[[ "$REPO" == "." ]] && REPO="$(pwd)"
[[ -d "$REPO/.bac" ]] || { echo "erro: .bac não encontrado em $REPO" >&2; exit 1; }

last=$(find "$REPO/.bac/draft" "$REPO/.bac/backlog" "$REPO/.bac"/sprint-* \
    -maxdepth 1 -name "FEAT-[0-9]*.md" \
    ! -name "*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9].md" \
    ! -name "*-blocker-*" \
    2>/dev/null \
  | grep -oP 'FEAT-\K[0-9]+' \
  | sort -n \
  | tail -1 || true)

next=$(( 10#${last:-0} + 1 ))
printf 'FEAT-%03d\n' "$next"
